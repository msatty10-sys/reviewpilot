# Shared Environment Variables for ReviewPilot
# Copy this to .env and fill in the values

# --- Backend Config ---
PROJECT_NAME=ReviewPilot
SECRET_KEY=  # Generate with: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days
SQLALCHEMY_DATABASE_URI=sqlite:///./sql_app.db
# For Production (PostgreSQL):
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@db:5432/reviewpilot

# --- Stripe Integration ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- SendGrid (Email) ---
SENDGRID_API_KEY=
FROM_EMAIL=

# --- Frontend Config ---
VITE_API_URL=http://localhost:8000/api/v1
